{
  "name": "shower-tracker",
  "private": true,
  "version": "1.3.4",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.11.1"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "clean": "rm -rf dist dev-dist playwright-report test-results",
    "build": "tsc -b && vite build",
    "build:github": "tsc -b && GITHUB_PAGES=true vite build",
    "build:vercel": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest --run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:ui": "vitest --ui --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test:all": "pnpm run test && pnpm run test:e2e",
    "test:deployment": "node scripts/test-deployment.js",
    "audit": "node scripts/lighthouse-audit.js",
    "audit:build": "pnpm run build && pnpm run preview & sleep 3 && node scripts/lighthouse-audit.js http://localhost:4173 && pkill -f 'vite preview'",
    "test:cross-browser": "node scripts/cross-browser-test.js",
    "optimize": "pnpm run build && pnpm run audit:build"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-switch": "^1.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.4",
    "lucide-react": "^0.542.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-swipeable": "^7.0.2",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.3.0",
    "happy-dom": "^18.0.1",
    "jest-axe": "^10.0.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.17",
    "terser": "^5.49.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.1.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.4"
  }
}
